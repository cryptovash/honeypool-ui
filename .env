# Blank if development. Domain if production.
NEXT_PUBLIC_DOMAIN_NAME=

# Locize API keys for localization.
NEXT_PUBLIC_LOCIZE_PROJECT_ID=
NEXT_PUBLIC_LOCIZE_VERSION=latest

# Only one is needed
# API keys for read only RPC calls.
# NEXT_PUBLIC_ALCHEMY_API_KEY=
# NEXT_PUBLIC_ETHERSCAN_API_KEY=
NEXT_PUBLIC_INFURA_ID=

# Optional
# Sentry DSN
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENV=
# SENTRY_REPO_NAME=pooltogether/v4-ui
# SENTRY_PROJECT=v4-ui
# SENTRY_ORG=pooltogether

# Optional
# API keys for extra wallet support.
# NEXT_PUBLIC_FORTMATIC_API_KEY=
# NEXT_PUBLIC_FORTMATIC_PRODUCTION_API_KEY=
# NEXT_PUBLIC_PORTIS_API_KEY=

# Optional
# Locize Dev API key for writing values.
NEXT_PUBLIC_LOCIZE_DEV_API_KEY=

# Optional
# Fathom API keys for analytics tracking.
# NEXT_PUBLIC_FATHOM_SITE_ID=

# Optional
# NEXT_PUBLIC_COINBASE_PAY_APP_ID=